# ── Meta Ad Library (free — developers.facebook.com) ──────
META_ACCESS_TOKEN=your_meta_user_token_here

# ── Email Enrichment (free tiers, comma-separated for key rotation) ───────────
# Hunter.io — https://hunter.io (50 searches/month free per key)
# Add multiple keys separated by commas for automatic rotation
HUNTER_API_KEYS=your_hunter_key_1,your_hunter_key_2

# Snov.io — https://snov.io (format: client_id:client_secret, comma-separated)
# Multiple accounts supported for rotation
SNOV_CREDENTIALS=client_id_1:client_secret_1,client_id_2:client_secret_2

# Prospeo — https://prospeo.io (100 credits/month free per key)
PROSPEO_API_KEYS=your_prospeo_key_1,your_prospeo_key_2

# Apollo.io — https://apollo.io (75 credits/month free per key)
# Used in the enrichment waterfall and ReAct harness discover_email tool.
APOLLO_API_KEYS=your_apollo_key_1

# Google Custom Search API (100 free searches/day)
# Used FIRST for LinkedIn/Domain discovery before falling back to Serper.
GOOGLE_SEARCH_API_KEYS=your_google_api_key_1,your_google_api_key_2
GOOGLE_SEARCH_CXS=your_cx_id_1,your_cx_id_2

# Serper.dev — https://serper.dev (2500 searches/month free per key)
# Used as fallback after Google Custom Search quota is exhausted.
SERPER_API_KEYS=your_serper_key_1,your_serper_key_2

# ── Storage ────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings (gear icon in the sidebar) -> API
# 3. SUPABASE_URL is the "Project URL" exactly as shown
# 4. SUPABASE_KEY is the service_role key (for RLS bypass)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── LLM (local, free) ─────────────────────────────────────
# Run: ollama pull qwen2.5:7b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── App ───────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
TIMEZONE=Asia/Kolkata

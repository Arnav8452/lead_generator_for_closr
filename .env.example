# ── Meta Ad Library (free — developers.facebook.com) ──────
META_ACCESS_TOKEN=your_meta_user_token_here

# ── Email Enrichment (all free tiers) ─────────────────────
HUNTER_API_KEY=your_hunter_key_here
SNOV_CLIENT_ID=your_snov_client_id_here
SNOV_CLIENT_SECRET=your_snov_client_secret_here
PROSPEO_API_KEY=your_prospeo_key_here

# ── Storage ────────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings (gear icon in the sidebar) -> API
# 3. SUPABASE_URL is the "Project URL" exactly as shown
# 4. SUPABASE_KEY is the "anon public" API key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# ── LLM (local, free) ─────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── App ───────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=production
TIMEZONE=Asia/Kolkata
